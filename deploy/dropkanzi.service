[Unit]
Description=Dropkanzi Docker Compose Stack
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/dropkanzi
ExecStart=/usr/bin/docker compose -f /opt/dropkanzi/deploy/docker-compose.prod.yml up -d --build
ExecStop=/usr/bin/docker compose -f /opt/dropkanzi/deploy/docker-compose.prod.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
