generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                String         @id @default(cuid())
  asin              String         @unique
  title             String?
  description       String?
  aboutText         String?        @db.Text
  bulletPoints      String[]
  attributes        Json?
  dimensions        String?
  brand             String?
  images            String[]
  rating            Float?
  reviewsCount      Int?
  price             Float?
  stock             String?
  isInStock         Boolean        @default(false)
  buyBoxSeller      String?
  isAmazonFulfilled Boolean        @default(false)
  isPrime           Boolean        @default(false)
  isPrimePantry     Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  fullFetchAt       DateTime?
  priceHistory      PriceHistory[]
  listings          Listing[]
}

model PriceHistory {
  id           Int      @id @default(autoincrement())
  asin         String
  price        Float?
  stock        String?
  isInStock    Boolean
  buyBoxSeller String?
  scrapedAt    DateTime @default(now())
  product      Product  @relation(fields: [asin], references: [asin])

  @@index([asin, scrapedAt(sort: Desc)])
}

model SellerAnalysis {
  id        String   @id @default(cuid())
  tenantId  String   @default("default")
  seller    String
  daysBack  Int
  scanType  String   @default("sold")
  listings  Json
  summary   Json
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([seller, scanType, createdAt(sort: Desc)])
}

/// Merged matched listings across all scans (7d + 30d + multiple sellers).
model FoundProduct {
  listingKey String   @id
  tenantId   String   @default("default")
  seller     String?
  daysBack   Int?
  payload    Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([tenantId, updatedAt(sort: Desc)])
  @@index([seller])
  @@index([updatedAt(sort: Desc)])
}

/// Product Finder Saved / Reserved lists (persisted server-side).
model PfLibraryProduct {
  listingKey String   @id
  tenantId   String   @default("default")
  bucket     String
  payload    Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([tenantId, bucket, updatedAt(sort: Desc)])
  @@index([bucket, updatedAt(sort: Desc)])
}

/// Snapshot before destructive clears — one-click recovery.
model PfDataArchive {
  id         String   @id @default(cuid())
  tenantId   String   @default("default")
  source     String
  listingKey String
  payload    Json
  reason     String
  createdAt  DateTime @default(now())

  @@index([tenantId, source, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
}

/// eBay seller live/active listings matched to Amazon.
model ActiveListingProduct {
  listingKey String   @id
  tenantId   String   @default("default")
  seller     String?
  payload    Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([tenantId, updatedAt(sort: Desc)])
  @@index([seller])
  @@index([updatedAt(sort: Desc)])
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  settings  Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

model PfScanJob {
  id           String   @id
  tenantId     String   @default("default")
  seller       String
  scanType     String
  daysBack     Int
  forceRefresh Boolean  @default(false)
  status       String   @default("queued")
  stage        String?
  progress     Json?
  error        String?
  result       Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, status, createdAt])
}

model MatchFeedback {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  titleHash     String
  suggestedAsin String
  action        String
  correctedAsin String?
  userId        String?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([titleHash, suggestedAsin])
}

model ScrapeJob {
  id                   String   @id @default(cuid())
  status               String   @default("pending")
  total                Int
  done                 Int      @default(0)
  failed               Int      @default(0)
  asins                String[]
  itemNotes            Json?
  itemStats            Json?
  totalBytesDownloaded Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Store {
  id           String   @id @default(cuid())
  ebayUsername String
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  country      String   @default("US")
  settings     Json?
  createdAt    DateTime @default(now())

  listings Listing[]
  orders   Order[]
}

model Listing {
  id                 String   @id @default(cuid())
  storeId            String
  asin               String
  ebayListingId      String?
  title              String
  price              Float
  quantity           Int
  condition          String
  status             String   @default("draft") // draft | active | oos | ended
  paymentPolicyId    String?
  returnPolicyId     String?
  fulfillmentPolicyId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [asin], references: [asin])

  @@index([storeId])
  @@index([asin])
}

model Order {
  id            String   @id @default(cuid())
  storeId       String
  ebayOrderId   String
  lineItemId    String
  asin          String?
  title         String
  image         String?

  status        String   @default("received_not_ordered") // received_not_ordered | ordered | tracking | delivered
  notes         String?

  targetUrl     String?
  buyer         String?
  qty           Int      @default(1)
  paidAmount    Float?

  sourceUrl     String?
  amazonPrice   Float?
  price         Float?
  profit        Float?

  sourceOrderUrl String?
  carrier       String?
  tracking      String?

  raw           Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store         Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, ebayOrderId, lineItemId])
  @@index([storeId, updatedAt(sort: Desc)])
  @@index([ebayOrderId])
}
