PROXY_USER=your_login
PROXY_PASS=your_password
PROXY_HOST=gw.dataimpulse.com
PROXY_PORT=823
PROXY_COUNTRY=us

POSTGRES_DB=pricehawk
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret123
DATABASE_URL=postgresql://admin:secret123@postgres:5432/pricehawk
REDIS_URL=redis://redis:6379

BACKEND_PORT=3001
SCRAPER_URL=http://scraper:8001

# Scraper: AOD aodAjaxMain — filters all=false = buy box only (~8-15KB)
SCRAPER_SKIP_AOD=false
AOD_FILTERS_ALL=false
PRICE_STREAM_MAX_BYTES=1000000
PRICE_CHECK_EVERY_BYTES=131072
AOD_PRICE_MAX_BYTES=65536
PRICE_FETCH_AOD_ATTEMPTS=3
PRICE_FETCH_DP_FALLBACK=true

# Bulk scrape speed (100 ASIN parallel target)
BULK_CONCURRENCY=40
BULK_CHUNK_SIZE=100
BULK_RETRY_ATTEMPTS=3
BULK_SESSION_POOL=6
BULK_PARALLEL_CHUNKS=2
BULK_UPSERT_PARALLEL=20
WORKER_CONCURRENCY=3
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
FRONTEND_URL=http://localhost:3000

# --- eBay OAuth (required for Connect eBay) ---
# Create keys: https://developer.ebay.com/my/keys
# Production keyset -> EBAY_SANDBOX=false
# Sandbox keyset    -> EBAY_SANDBOX=true
#
# EBAY_CLIENT_ID     = App ID (Client ID) from the keyset — NOT Dev ID
# EBAY_CLIENT_SECRET = Cert ID (Client Secret) from the same keyset
# EBAY_REDIRECT_URI  = RuName string from Developer Portal → User Tokens
#                      (NOT http://localhost/... — that URL goes into RuName settings)
# RuName "Auth Accepted URL" must be exactly:
#   http://localhost:3001/api/auth/ebay/callback
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_SANDBOX=false

# Product Finder — proxy cost controls ($1/GB residential)
FINDER_MAX_MATCH_GROUPS=400
FINDER_MISS_CACHE_TTL=172800
FINDER_CAPTCHA_ABORT_AFTER=8
FINDER_CLEAR_MATCH_CACHE=false
# Analyze = match only by default; use Fetch prices in UI when you need profit.
# Amazon AOD price during seller analyze (per matched ASIN). false = match only, fetch prices in UI later.
FINDER_FETCH_PRICES_ON_ANALYZE=true
SERP_STREAM_MAX_BYTES=307200
SERP_FULL_MAX_BYTES=1048576
SERP_PARSE_EVERY_BYTES=12000
FINDER_SERP_CANDIDATES=8
FINDER_SERP_CONCURRENCY=8
FINDER_MAX_SERP_QUERIES=2
FINDER_PROXY_CONCURRENCY=2
FINDER_IMAGE_CANDIDATES=5
IMAGE_CHECK_MIN_TEXT=0.38
IMAGE_CHECK_MAX_TEXT=0.81

# SigLIP image matching
SIGLIP_MODEL=google/siglip-base-patch16-224
IMAGE_DOWNLOAD_TIMEOUT=8

FINDER_AOD_MAX_BYTES=28672
FINDER_AOD_RETRIES=2
FINDER_AOD_PARSE_EVERY=4096
FINDER_PRICE_DP_FALLBACK=true
FINDER_MATCH_TIMEOUT_SEC=60
FINDER_PRICE_CONCURRENCY=50
FINDER_PRICE_MAX_ASINS=1000
FINDER_PRICE_SESSION_POOL=16
FINDER_PRICE_MAX_CONCURRENCY=60
FINDER_MATCH_CONCURRENCY=6
EBAY_PROXY_MODE=always
# Amazon SERP: true = residential proxy only (never host IP)
FINDER_SERP_USE_PROXY=true
FINDER_CLAUDE_MATCH=false
FINDER_VISION_MATCH=false

# Product Finder matching (optional — Claude title clean + vision strategies)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
